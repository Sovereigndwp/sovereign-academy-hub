    "checklists": {
      "bitcoin_custody_checklist": {
        "title": "Bitcoin Self-Custody Security Checklist",
        "type": "interactive_checklist",
        "sections": [
          {
            "section_title": "Before You Start",
            "items": [
              "✓ Understand what you're doing (take our course)",
              "✓ Practice with small amounts first ($20-100)",
              "✓ Have 2-3 hours of uninterrupted time",
              "✓ Choose your wallet type (hardware recommended)",
              "✓ Prepare secure storage for seed phrase"
            ]
          },
          {
            "section_title": "Setting Up Your Wallet",
            "items": [
              "✓ Buy wallet from official manufacturer",
              "✓ Verify authenticity/tamper seals",
              "✓ Update firmware to latest version",
              "✓ Generate new seed phrase (don't use pre-generated)",
              "✓ Write seed phrase on paper (never digital)"
            ]
          },
          {
            "section_title": "Securing Your Seed",
            "items": [
              "✓ Write clearly and double-check spelling",
              "✓ Create 2-3 physical copies",
              "✓ Store copies in different secure locations",
              "✓ Consider metal backup for long-term storage",
              "✓ Never photograph or type seed phrase"
            ]
          },
          {
            "section_title": "Testing Your Setup",
            "items": [
              "✓ Send small test amount to wallet",
              "✓ Verify transaction appears in wallet",
              "✓ Practice sending Bitcoin back out",
              "✓ Test wallet recovery with seed phrase",
              "✓ Only add larger amounts after successful tests"
            ]
          }
        ],
        "dimensions": "800x1200",
        "style": "clean_professional",
        "branding": "sovereign_academy"
      },
      "emergency_fund_checklist": {
        "title": "Emergency Fund Action Plan",
        "type": "progress_checklist",
        "phases": [
          {
            "phase": "Week 1: Assessment",
            "tasks": [
              "✓ Track all expenses for 7 days",
              "✓ Calculate true monthly costs",
              "✓ Identify largest expense categories",
