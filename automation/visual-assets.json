          {
            "phase": "Month 1-3: Building",
            "tasks": [
              "✓ Maintain automatic contributions",
              "✓ Add windfalls (tax refunds, bonuses)",
              "✓ Resist temptation to use fund",
              "✓ Celebrate small milestones"
            ]
          },
          {
            "phase": "Ongoing: Maintenance",
            "tasks": [
              "✓ Review fund size annually",
              "✓ Adjust for lifestyle changes",
              "✓ Keep funds easily accessible",
              "✓ Only use for true emergencies"
