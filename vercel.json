{
  "alias": ["thesovereign.academy"],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/institutional",
      "destination": "/institutional/index.html"
    },
    {
      "source": "/institutional/",
      "destination": "/institutional/index.html"
    },
    {
      "source": "/about",
      "destination": "/about/index.html"
    },
    {
      "source": "/about/",
      "destination": "/about/index.html"
    }
  ]
}
